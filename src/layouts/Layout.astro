---
import Navbar from '../components/Navbar.astro';

interface Props {
	eagerReveal?: boolean;
}

const { eagerReveal } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body class="min-h-screen bg-[#030207] text-white antialiased relative" data-eager-reveal={eagerReveal ? '' : undefined}>
		<div class="absolute top-0 left-0 w-full h-[800px] bg-gradient-to-b from-[#7c3aed] to-[#030207] -z-10 pointer-events-none"></div>
		<Navbar />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>