const getYearsOfExperience = () => {
	const today = new Date();
	const currentYear = today.getFullYear();
	const startYear = 2022;
	const startMonth = 8;
	
	let yearsExp = currentYear - startYear;
	
	if (today.getMonth() < startMonth) {
		yearsExp -= 1;
	}
	
	return yearsExp;
};

