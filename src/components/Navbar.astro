<script>
    const navbarShell = document.getElementById("navbar-shell");

    const updateNavbar = () => {
        if (!navbarShell) return;

        const scrolled = window.scrollY > 550;

        navbarShell.style.background = scrolled
            ? "rgba(22, 21, 28, 0.95)"
            : "rgba(10, 10, 10, 0.5)";
        navbarShell.style.paddingTop = scrolled ? "12px" : "16px";
        navbarShell.style.paddingBottom = scrolled ? "12px" : "16px";
    };

    updateNavbar();
    window.addEventListener("scroll", updateNavbar, { passive: true });
</script>
