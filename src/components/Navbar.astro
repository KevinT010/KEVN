<nav class="p-4 fixed top-0 w-full z-50 flex justify-center">
    <div id="navbar-shell" class="w-full max-w-7xl px-6 py-4 rounded-2xl transition-all duration-300 border border-gray-900 border-t-[2px]">
        <div class="flex h-10 items-center justify-between relative">
            <div class="flex items-center">
                <a href="/" aria-label="Home">
                    <img src="/assets/images/KEVIN.png" alt="MySite Logo" class="h-42 w-42 mr-2 mt-1" />
                </a>
            </div>
            
            <div class="hidden md:flex absolute left-1/2 transform -translate-x-1/2 items-center space-x-6 whitespace-nowrap">
                <a href="#1" class="text-white hover:bg-white/10 transition-colors duration-200 rounded-xl px-3 py-2">About me</a>
                <a href="#2" class="text-white hover:bg-white/10 transition-colors duration-200 rounded-xl px-3 py-2">Skills</a>
                <a href="#3" class="text-white hover:bg-white/10 transition-colors duration-200 rounded-xl px-3 py-2">Portfolio</a>
                <a href="#4" class="text-white hover:bg-white/10 transition-colors duration-200 rounded-xl px-3 py-2">Contact</a>
            </div>

            <div class="flex items-center space-x-3"></div>
        </div>
    </div>
</nav>

<script>
    const navbarShell = document.getElementById("navbar-shell");

    const updateNavbar = () => {
        if (!navbarShell) return;

        const scrolled = window.scrollY > 550;

        navbarShell.style.background = scrolled
            ? "rgba(5, 5, 5, 0.12)"
            : "rgba(10, 10, 10, 0.7)";
        navbarShell.style.boxShadow = scrolled
            ? "0 10px 40px -10px rgba(0, 0, 0, 0.7), 0 0 30px rgba(255, 255, 255, 0.5)"
            : "0 4px 24px rgba(0, 0, 0, 0.3), 0 0 20px rgba(255, 255, 255, 0.4)";
        navbarShell.style.backdropFilter = scrolled
            ? "blur(16px)"
            : "blur(8px)";
    };

    updateNavbar();
    window.addEventListener("scroll", updateNavbar, { passive: true });
</script>
